Algoritmo "aumento"
// Disciplina   : [Linguagem e Lµgica de ProgramaÓÐo]
// Professor   : Antonio Carlos Nicolodi 
// DescriÓÐo   : Aqui vocõ descreve o que o programa faz! (funÓÐo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 09/03/2026
Var
    salario, aumento : real


Inicio

         escreva("Informe sua folha salarial em R$ ")
         leia(salario)

      se (salario > 0 ) e (salario <= 1000) entao
       aumento <- salario * 1.2
        escreva("Seu Novo SalÃrio Õ de R$ ",aumento:4:2)
         senao
          se (salario > 1000 ) e (salario <= 3000) entao
           aumento <- salario * 1.15
            escreva("Seu Novo SalÃrio Õ de R$ ",aumento:4:2)
             senao
              se (salario > 3000 ) e (salario <= 8000) entao
               aumento <- salario * 1.1
                escreva("Seu Novo SalÃrio Õ de R$ ",aumento:4:2)
                 senao
                  se (salario > 8000 ) entao
                   aumento <- salario * 1.05
                    escreva("Seu Novo SalÃrio Õ de R$ ",aumento:4:2)
                     senao
                      escreva("Vocõ nÐo Õ possÚvel distinguir o aumento")
                  fimse
              fimse
          fimse
      fimse

Fimalgoritmo